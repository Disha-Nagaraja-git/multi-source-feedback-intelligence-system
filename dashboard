import streamlit as st
import pandas as pd
from fetch_reviews import fetch_google_play_reviews
from sentiment_analysis import analyze_sentiment

st.title("Multi-Source Feedback Intelligence System")

app_id = st.text_input("Enter App ID", "com.whatsapp")

if st.button("Fetch Reviews"):

    df = fetch_google_play_reviews(app_id)

    sentiments = []

    for review in df["review"]:
        sentiment, _ = analyze_sentiment(review)
        sentiments.append(sentiment)

    df["sentiment"] = sentiments

    st.subheader("Reviews Data")
    st.dataframe(df)

    sentiment_counts = df["sentiment"].value_counts()

    st.subheader("Sentiment Distribution")
    st.bar_chart(sentiment_counts)
